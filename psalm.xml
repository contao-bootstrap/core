<?xml version="1.0"?>
<psalm xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://getpsalm.org/schema/config" errorLevel="3" hideExternalErrors="true" findUnusedCode="false" xsi:schemaLocation="https://getpsalm.org/schema/config https://getpsalm.org/schema/config" findUnusedBaselineEntry="false">
    <projectFiles>
        <directory name="src"/>
        <ignoreFiles>
            <file name="src/DependencyInjection/Configuration.php"/>
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <DeprecatedClass>
            <errorLevel type="suppress">
                <referencedClass name="Contao\Template"/>
            </errorLevel>
        </DeprecatedClass>
        <DeprecatedMethod>
            <errorLevel type="suppress">
                <!--
                    introspectTable() deprecated in DBAL 4.4 in favor of introspectTableByUnquotedName().
                    The replacement is not available in DBAL ^3.9 || ^4.0-4.3, so suppressed for compatibility.
                -->
                <referencedMethod name="Doctrine\DBAL\Schema\AbstractSchemaManager::introspectTable"/>
            </errorLevel>
        </DeprecatedMethod>
    </issueHandlers>

    <universalObjectCrates>
        <class name="Contao\Database\Result"/>
    </universalObjectCrates>
</psalm>
